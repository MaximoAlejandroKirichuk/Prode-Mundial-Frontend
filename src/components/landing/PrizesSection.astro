<section class="py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Header -->
    <div class="mb-14 max-w-2xl">
      <h2
        class="text-3xl font-extrabold tracking-tight lg:text-4xl headline-accent inline-block"
      >
        Premios a la altura de la campeona del mundo
      </h2>
      <p class="mt-6 text-muted-foreground max-w-[60ch] leading-relaxed">
        Participá por premios exclusivos pensados para quienes viven la pasión
        por la Selección Argentina. Experiencias inolvidables, beneficios premium
        y premios únicos para celebrar a la campeona del mundo.
      </p>
    </div>

    <!-- Prize hierarchy: asymmetric layout, not equal cards -->
    <div class="grid gap-4 lg:grid-cols-12">
      <!-- 1° PREMIO — full-width hero block -->
      <div
        class="lg:col-span-12 top-stripe-celeste bg-cancha-dark p-8 sm:p-10 text-white"
      >
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-[60ch]">
            <span
              class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-cancha-celeste"
            >
              1° Premio
            </span>
            <h3 class="mt-3 text-2xl font-extrabold tracking-tight lg:text-3xl">
              Entradas para todos los partidos de local del campeonato
            </h3>
            <p class="mt-3 text-white/70 leading-relaxed">
              El ganador y un acompañante viven cada fecha de local del
              campeonato. Una experiencia completa de fútbol en vivo para el
              premio mayor del Prode.
            </p>
          </div>
          <div
            class="shrink-0 flex items-center justify-center w-16 h-16 rounded-full border-2 border-cancha-celeste/40"
            aria-hidden="true"
          >
            <svg
              class="w-7 h-7 text-cancha-celeste"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M12 15l-2 5l9-9l-5 2l2-5l-9 9z" />
            </svg>
          </div>
        </div>
      </div>

      <!-- 2° PREMIO — half-width feature block -->
      <div
        class="lg:col-span-6 bg-cancha-dark/90 p-8 text-white"
      >
        <span
          class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-cancha-celeste"
        >
          2° Premio
        </span>
        <h3 class="mt-3 text-xl font-bold tracking-tight">
          Entradas para todos los partidos de local de la copa continental
        </h3>
        <p class="mt-2 text-sm text-white/70 leading-relaxed max-w-[48ch]">
          El ganador y un acompañante disfrutan cada partido de local de la
          competencia continental. Fútbol internacional en vivo.
        </p>
      </div>

      <!-- 3° – 10° — compact grouped block -->
      <div
        class="lg:col-span-6 p-8 bg-cancha-dark/80 text-white"
      >
        <span
          class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-cancha-celeste"
        >
          3° al 10° puesto
        </span>
        <h3 class="mt-3 text-xl font-bold tracking-tight">
          Vouchers para restaurantes VIP de CABA
        </h3>
        <p class="mt-2 text-sm text-white/70 leading-relaxed max-w-[48ch]">
          Ocho ganadores reciben vouchers válidos para 2 personas en los
          mejores restaurantes VIP de la Ciudad Autónoma de Buenos Aires.
        </p>
      </div>

      <!-- 11° – 13° — compact block -->
      <div
        class="lg:col-span-6 sm:col-span-1 p-8 bg-cancha-dark/70 text-white"
      >
        <span
          class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-cancha-celeste"
        >
          11° al 13° puesto
        </span>
        <h3 class="mt-3 text-xl font-bold tracking-tight">
          Paleta de pádel a elección
        </h3>
        <p class="mt-2 text-sm text-white/70 leading-relaxed max-w-[48ch]">
          Tres ganadores eligen su paleta de pádel entre las mejores marcas
          del mercado.
        </p>
      </div>

      <!-- 14° – 15° — compact block -->
      <div
        class="lg:col-span-6 sm:col-span-1 p-8 bg-cancha-dark/60 text-white"
      >
        <span
          class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-cancha-celeste"
        >
          14° al 15° puesto
        </span>
        <h3 class="mt-3 text-xl font-bold tracking-tight">
          Camiseta de la Selección campeona del mundo 2022
        </h3>
        <p class="mt-2 text-sm text-white/70 leading-relaxed max-w-[48ch]">
          Dos ganadores se llevan la camiseta de la Selección Argentina,
          campeona del mundo en Qatar 2022.
        </p>
      </div>
    </div>

    <!-- Single CTA -->
    <div class="mt-12">
      <a
        href="#signup"
        class="inline-flex h-12 items-center justify-center rounded-sm bg-primary px-8 text-sm font-bold tracking-wide text-primary-foreground shadow-sm transition-[transform,box-shadow,background-color] duration-200 ease-out hover:bg-primary/90 hover:-translate-y-[1px] hover:shadow-md active:translate-y-0 active:scale-[0.98] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
      >
        Quiero Participar
      </a>
    </div>
  </div>
</section>
