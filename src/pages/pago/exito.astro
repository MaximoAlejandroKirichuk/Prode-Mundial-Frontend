---
import Layout from "../../layouts/Layout.astro";
import { PaymentReturnIsland } from "../../components/PaymentReturnIsland";
---

<Layout
  title="Pago Recibido | Prode Mundial 2026"
  description="Volviste de Mercado Pago. La confirmación final de tu inscripción al Prode Mundial depende de la verificación del pago. Recibirás el acceso por correo apenas se confirme."
>
  <main class="relative flex min-h-[90dvh] items-center justify-center overflow-hidden px-4 py-20">
    <!-- Decorative background textures — same as landing sections -->
    <div class="absolute inset-0 pitch-texture pointer-events-none" aria-hidden="true"></div>
    <div class="absolute inset-0 tribuna-noise pointer-events-none opacity-60" aria-hidden="true"></div>
    <!-- Celeste accent line at top — stadium feel -->
    <div class="absolute top-0 left-0 right-0 h-[3px] bg-cancha-celeste" aria-hidden="true"></div>

    <div class="relative w-full">
      <PaymentReturnIsland variant="success" client:load />
    </div>
  </main>
</Layout>
