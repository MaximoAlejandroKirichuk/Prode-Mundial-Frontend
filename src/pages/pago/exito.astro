---
import Layout from "../../layouts/Layout.astro";
import { PaymentReturnIsland } from "../../components/PaymentReturnIsland";
---

<Layout
  title="Pago Recibido | Prode Mundial 2026"
  description="Volviste de Mercado Pago. La confirmación final de tu inscripción al Prode Mundial depende de la verificación del pago. Recibirás el acceso por correo apenas se confirme."
>
  <main class="flex min-h-[80dvh] items-center justify-center px-4 py-16">
    <div class="w-full max-w-md">
      <PaymentReturnIsland variant="success" client:load />
    </div>
  </main>
</Layout>
